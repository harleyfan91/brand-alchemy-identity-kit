{
  "name": "@identity-kit/generation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "new-cta-frame": "node scripts/new-cta-frame.mjs",
    "dev:cta-frames": "vite --config dev/cta-frames/vite.config.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --exclude 'src/**/*.integration.test.ts'",
    "test:pro-smoke": "vitest run --config vitest.proSmoke.config.ts",
    "test:watch": "vitest",
    "generate": "tsx src/cli/writeCorePdfs.ts",
    "generate:pro-pdfs": "tsx src/cli/writeProPdfs.ts",
    "lint": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.0",
    "@fontsource/cormorant-garamond": "^5.2.11",
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/dm-serif-display": "^5.2.8",
    "@fontsource/fraunces": "^5.2.9",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/lato": "^5.2.7",
    "@fontsource/manrope": "^5.2.8",
    "@fontsource/open-sans": "^5.2.7",
    "@fontsource/outfit": "^5.2.8",
    "@fontsource/playfair-display": "^5.2.8",
    "@fontsource/roboto": "^5.2.10",
    "@fontsource/source-serif-4": "^5.2.9",
    "@fontsource/syne": "^5.2.7",
    "@identity-kit/brand-assets": "*",
    "@identity-kit/pdf-chrome": "*",
    "@identity-kit/shared": "*",
    "@react-pdf/renderer": "^4.3.1",
    "react": "^19.2.4",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.4.2",
    "react-dom": "^19.2.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^3.2.4"
  }
}
